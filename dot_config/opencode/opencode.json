{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": ["~/.agents/skills"]
  },
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local (llm-serve)",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit": {
          "name": "Qwen3.5-27B Opus Distilled"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server", "-e", "EXA_API_KEY"]
    }
  }
}
