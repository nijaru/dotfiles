{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "instructions": ["AGENTS.md"],
  "compaction": {
    "strategy": "auto"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server", "-e", "EXA_API_KEY"]
    }
  }
}
