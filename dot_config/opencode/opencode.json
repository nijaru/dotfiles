{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": ["~/.agents/skills"]
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "gemma4:26b": { "name": "Gemma 4 26B", "limit": { "context": 131072 } },
        "gemma4:31b": { "name": "Gemma 4 31B", "limit": { "context": 131072 } }
      }
    },
    "ollama-fedora": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Fedora)",
      "options": {
        "baseURL": "http://fedora:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "gemma4:31b-64k": {
          "name": "Gemma 4 31B 64K",
          "limit": { "context": 65536 }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server", "-e", "EXA_API_KEY"]
    }
  }
}
