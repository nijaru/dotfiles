{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": ["~/.agents/skills"]
  },
  "model": "fedora/qwen3.6:27b",
  "provider": {
    "fedora": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Fedora llama.cpp",
      "options": {
        "baseURL": "http://fedora:8080/v1",
        "apiKey": "llama"
      },
      "models": {
        "qwen3.6:27b": {
          "name": "Qwen3.6 27B 128K",
          "limit": { "context": 131072, "output": 32768 }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server", "-e", "EXA_API_KEY"]
    }
  }
}
