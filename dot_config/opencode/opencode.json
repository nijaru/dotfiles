{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": ["~/.agents/skills"]
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen3.6:latest": {
          "name": "Qwen3.6 35B-A3B",
          "limit": { "context": 262144, "output": 32768 }
        }
      }
    },
    "ollama-fedora": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Fedora)",
      "options": {
        "baseURL": "http://fedora:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen3.6:27b": {
          "name": "Qwen3.6 27B 128K",
          "limit": { "context": 131072, "output": 32768 }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server", "-e", "EXA_API_KEY"]
    }
  }
}
