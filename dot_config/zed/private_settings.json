      "language_servers": ["ruff", "ty"],
      "code_actions_on_format": {
        "source.fixAll": true,
        "source.organizeImports": true
      },
      "formatter": []
    },
    "Rust": {
      "hard_tabs": false,
      "code_actions_on_format": {
        "source.fixAll": true,
        "source.organizeImports": true
      }
    }
  }
