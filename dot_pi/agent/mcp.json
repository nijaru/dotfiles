{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "$EXA_API_KEY"
      }
    },
    "parallel": {
      "httpUrl": "https://task-mcp.parallel.ai/mcp",
      "headers": {
        "Authorization": "Bearer $PARALLEL_API_KEY"
      }
    }
  }
}
